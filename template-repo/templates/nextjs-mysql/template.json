{
  "key": "nextjs-mysql",
  "name": "Next.js + MySQL",
  "stack": {
    "app": "Next.js 15 + React 19 + Prisma",
    "database": "MySQL 8"
  },
  "run": {
    "database": "docker compose up -d",
    "development": "npm install && npm run prisma:generate && npm run db:push && npm run dev"
  },
  "exampleFiles": {
    "backendController": "app/api/todos/route.ts",
    "frontendPage": "app/page.tsx",
    "frontendComponent": "components/create-todo-form.tsx",
    "frontendApi": "lib/prisma.ts",
    "frontendPageTest": "__tests__/page.test.tsx",
    "dbMigration": "prisma/schema.prisma"
  }
}
