{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@smartark/domain/*": ["../packages/domain/src/*"],
      "@smartark/api-sdk": ["../packages/api-sdk/src/index.ts"],
      "@smartark/constants": ["../packages/constants/src/index.ts"]
    },
    "types": ["@dcloudio/types"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "../packages/**/*.ts"]
}
