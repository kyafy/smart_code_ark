## Smart Code Ark - Environment Example
## 将本文件复制为 .env（不要提交 .env），按需修改

## MySQL（本地运行后端时一般用 localhost；docker compose 内用 mysql）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartark
DB_USER=smartark
DB_PASSWORD=smartark

## Redis（本地运行后端时一般用 localhost；docker compose 内用 redis）
REDIS_HOST=localhost
REDIS_PORT=6379

## JWT（开发环境示例；生产环境必须替换为强随机值）
JWT_SECRET=change-me
JWT_TTL_SECONDS=604800

## OpenAI 兼容模型服务（DashScope Compatible Mode 示例）
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
MODEL_API_KEY=YOUR_MODEL_KEY
MODEL_MOCK_ENABLED=false

## 模型名称（示例）
CHAT_MODEL=qwen-plus
CODE_MODEL=qwen-plus

## LangChain Runtime / Sidecar
LANGCHAIN_ENABLED=false
LANGCHAIN_SIDECAR_BASE_URL=http://localhost:18080
LANGCHAIN_SIDECAR_TIMEOUT_MS=3000
LANGCHAIN_SIDECAR_API_VERSION=v1
LANGCHAIN_RUNTIME_MODEL_ENABLED=false
LANGCHAIN_RUNTIME_BASE_URL=http://localhost:18080
LANGCHAIN_RUNTIME_TIMEOUT_MS=45000
LANGCHAIN_RUNTIME_CODEGEN_GRAPH_ENABLED=false
LANGCHAIN_RUNTIME_PAPER_GRAPH_ENABLED=false

## LangSmith (optional, used when LANGCHAIN_ENABLE_LANGSMITH=true)
LANGCHAIN_ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=smartark-langchain-runtime

## Embedding（按百炼“文本与多模态向量化”接入）
RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_EMBEDDING_DIMENSION=1024
