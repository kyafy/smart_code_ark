## Smart Code Ark - Environment Example
## 将本文件复制为 .env（不要提交 .env），按需修改

## MySQL（本地运行后端时一般用 localhost；docker compose 内用 mysql）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartark
DB_USER=smartark
DB_PASSWORD=smartark

## Redis（本地运行后端时一般用 localhost；docker compose 内用 redis）
REDIS_HOST=localhost
REDIS_PORT=6379

## JWT（开发环境示例；生产环境必须替换为强随机值）
JWT_SECRET=change-me
JWT_TTL_SECONDS=604800

## OpenAI 兼容模型服务（DashScope Compatible Mode 示例）
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
MODEL_API_KEY=YOUR_MODEL_KEY
MODEL_MOCK_ENABLED=false

## 模型名称（示例）
CHAT_MODEL=qwen-plus
CODE_MODEL=qwen-plus

## Embedding（按百炼“文本与多模态向量化”接入）
RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_EMBEDDING_DIMENSION=1024

## Jeecg codegen sidecar (docker-compose default)
CODEGEN_JEECG_ENABLED=true
CODEGEN_JEECG_BASE_URL=http://localhost:19090
CODEGEN_JEECG_RENDER_PATH=/api/codegen/jeecg/render
CODEGEN_JEECG_TIMEOUT_MS=8000
CODEGEN_INTERNAL_PROVIDER_ORDER=local_template,jeecg
CODEGEN_INTERNAL_HYBRID_PROVIDER_ORDER=local_template,jeecg
CODEGEN_INTERNAL_STRICT_PROVIDER_ORDER=local_template,jeecg
CODEGEN_LOCAL_TEMPLATE_ENABLED=true
CODEGEN_LOCAL_TEMPLATE_PATH_REWRITE_ENABLED=true
CODEGEN_LOCAL_TEMPLATE_CONTENT_REWRITE_ENABLED=true
CODEGEN_LOCAL_TEMPLATE_EXTENSION_REWRITE_ENABLED=true
CODEGEN_LOCAL_TEMPLATE_OVERWRITE_TARGET=true

## Jeecg real engine upstream (sidecar -> JeecgBoot)
JEECG_UPSTREAM_BASE_URL=http://localhost:8080/jeecg-boot
JEECG_LOGIN_PATH=/sys/login
JEECG_CODEGEN_PATH=/online/cgform/api/codeGenerate
JEECG_TOKEN_HEADER=X-Access-Token
JEECG_TOKEN_JSON_PATH=result.token
JEECG_ACCESS_TOKEN=
JEECG_USERNAME=
JEECG_PASSWORD=
JEECG_REQUEST_TIMEOUT_MS=45000

## Release pipeline
RELEASE_ENABLED=true
RELEASE_COMMAND_EXECUTION_ENABLED=true
RELEASE_TIMEOUT_SECONDS=900
RELEASE_REGISTRY_PREFIX=
RELEASE_VERIFY_HEALTH_URL=
RELEASE_K8S_NAMESPACE=
RELEASE_K8S_ROLLBACK_ENABLED=true
RELEASE_K8S_ROLLBACK_KINDS=deployment,statefulset,daemonset
