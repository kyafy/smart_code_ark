+package org.jeecg.boot.starter.codegen.client;
+
+import com.fasterxml.jackson.core.JsonProcessingException;
+import com.fasterxml.jackson.databind.ObjectMapper;
+import org.jeecg.boot.starter.codegen.prop.CodegenClientProperties;
+import org.springframework.http.HttpEntity;
+import org.springframework.http.HttpHeaders;
+import org.springframework.http.MediaType;
+import org.springframework.http.ResponseEntity;
+import org.springframework.util.StringUtils;
+import org.springframework.web.client.RestTemplate;
+
+import javax.crypto.Mac;
+import javax.crypto.spec.SecretKeySpec;
+import java.net.URI;
+import java.nio.charset.StandardCharsets;
+import java.security.MessageDigest;
+import java.util.Map;
+import java.util.UUID;
+
+/**
+ * Thin client for Jeecg internal codegen endpoint.
+ */
+public class JeecgCodegenClient {
+
+    private final RestTemplate restTemplate;
+    private final CodegenClientProperties properties;
+    private final ObjectMapper objectMapper;
+
+    public JeecgCodegenClient(RestTemplate restTemplate, CodegenClientProperties properties) {
+        this.restTemplate = restTemplate;
+        this.properties = properties;
+        this.objectMapper = new ObjectMapper();
+    }
+
+    public ResponseEntity<String> render(Map<String, Object> payload) {
+        String body = toJson(payload == null ? Map.of() : payload);
+        String url = joinUrl(properties.getBaseUrl(), properties.getRenderPath());
+        HttpHeaders headers = new HttpHeaders();
+        headers.setContentType(MediaType.APPLICATION_JSON);
+        headers.setAccept(java.util.List.of(MediaType.APPLICATION_JSON));
+        addSignHeaders(headers, body, URI.create(url).getRawPath());
+        return restTemplate.postForEntity(url, new HttpEntity<>(body, headers), String.class);
+    }
+
+    private String joinUrl(String baseUrl, String path) {
+        String base = baseUrl == null ? "" : baseUrl.trim();
+        String p = StringUtils.hasText(path) ? path.trim() : "/internal/codegen/render";
+        if (!p.startsWith("/")) {
+            p = "/" + p;
+        }
+        if (base.endsWith("/")) {
+            base = base.substring(0, base.length() - 1);
+        }
+        return base + p;
+    }
+
+    private void addSignHeaders(HttpHeaders headers, String body, String rawPath) {
+        if (!StringUtils.hasText(properties.getSignSecret())) {
+            return;
+        }
+        String timestamp = String.valueOf(System.currentTimeMillis());
+        String nonce = UUID.randomUUID().toString().replace("-", "");
+        String bodySha = sha256Hex(body);
+        String signBase = "POST\n" + rawPath + "\n" + timestamp + "\n" + nonce + "\n" + bodySha;
+        String signature = hmacSha256Hex(properties.getSignSecret(), signBase);
+
+        headers.add(properties.getHeaderAppId(), properties.getAppId());
+        headers.add(properties.getHeaderTimestamp(), timestamp);
+        headers.add(properties.getHeaderNonce(), nonce);
+        headers.add(properties.getHeaderBodySha256(), bodySha);
+        headers.add(properties.getHeaderSignature(), signature);
+        headers.add(properties.getHeaderSignVersion(), properties.getSignVersion());
+    }
+
+    private String toJson(Map<String, Object> payload) {
+        try {
+            return objectMapper.writeValueAsString(payload);
+        } catch (JsonProcessingException ex) {
+            throw new IllegalStateException("serialize payload failed", ex);
+        }
+    }
+
+    private String sha256Hex(String value) {
+        try {
+            MessageDigest digest = MessageDigest.getInstance("SHA-256");
+            return hex(digest.digest(value.getBytes(StandardCharsets.UTF_8)));
+        } catch (Exception ex) {
+            throw new IllegalStateException("sha256 compute failed", ex);
+        }
+    }
+
+    private String hmacSha256Hex(String secret, String value) {
+        try {
+            Mac mac = Mac.getInstance("HmacSHA256");
+            mac.init(new SecretKeySpec(secret.getBytes(StandardCharsets.UTF_8), "HmacSHA256"));
+            return hex(mac.doFinal(value.getBytes(StandardCharsets.UTF_8)));
+        } catch (Exception ex) {
+            throw new IllegalStateException("hmac compute failed", ex);
+        }
+    }
+
+    private String hex(byte[] bytes) {
+        StringBuilder sb = new StringBuilder(bytes.length * 2);
+        for (byte b : bytes) {
+            sb.append(String.format("%02x", b));
+        }
+        return sb.toString();
+    }
+}

