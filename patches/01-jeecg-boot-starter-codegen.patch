+package org.jeecg.boot.starter.codegen.config;
+
+import org.jeecg.boot.starter.codegen.client.JeecgCodegenClient;
+import org.jeecg.boot.starter.codegen.prop.CodegenClientProperties;
+import org.springframework.boot.autoconfigure.condition.ConditionalOnMissingBean;
+import org.springframework.boot.autoconfigure.condition.ConditionalOnProperty;
+import org.springframework.boot.context.properties.EnableConfigurationProperties;
+import org.springframework.context.annotation.Bean;
+import org.springframework.context.annotation.Configuration;
+import org.springframework.http.client.SimpleClientHttpRequestFactory;
+import org.springframework.util.StringUtils;
+import org.springframework.web.client.RestTemplate;
+
+/**
+ * Auto configuration for Jeecg internal codegen client.
+ */
+@Configuration
+@EnableConfigurationProperties(CodegenClientProperties.class)
+public class CodegenClientAutoConfiguration {
+
+    @Bean("jeecgCodegenRestTemplate")
+    @ConditionalOnProperty(prefix = CodegenClientProperties.PREFIX, name = "enabled", havingValue = "true")
+    @ConditionalOnMissingBean(name = "jeecgCodegenRestTemplate")
+    public RestTemplate jeecgCodegenRestTemplate(CodegenClientProperties properties) {
+        SimpleClientHttpRequestFactory factory = new SimpleClientHttpRequestFactory();
+        int timeout = Math.max(1000, properties.getTimeoutMs());
+        factory.setConnectTimeout(timeout);
+        factory.setReadTimeout(timeout);
+        return new RestTemplate(factory);
+    }
+
+    @Bean
+    @ConditionalOnProperty(prefix = CodegenClientProperties.PREFIX, name = "enabled", havingValue = "true")
+    @ConditionalOnMissingBean
+    public JeecgCodegenClient jeecgCodegenClient(RestTemplate jeecgCodegenRestTemplate,
+                                                 CodegenClientProperties properties) {
+        if (!StringUtils.hasText(properties.getBaseUrl())) {
+            throw new IllegalArgumentException("jeecg.codegen.client.baseUrl cannot be blank");
+        }
+        return new JeecgCodegenClient(jeecgCodegenRestTemplate, properties);
+    }
+}

