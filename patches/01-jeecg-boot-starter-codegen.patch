+package org.jeecg.boot.starter.codegen.prop;
+
+import lombok.Data;
+import org.springframework.boot.context.properties.ConfigurationProperties;
+
+/**
+ * Internal codegen client configuration.
+ */
+@Data
+@ConfigurationProperties(prefix = CodegenClientProperties.PREFIX)
+public class CodegenClientProperties {
+    public static final String PREFIX = "jeecg.codegen.client";
+
+    private boolean enabled = false;
+    private String baseUrl = "http://localhost:8080/jeecg-boot";
+    private String renderPath = "/internal/codegen/render";
+    private int timeoutMs = 30000;
+
+    private String appId = "smart_code_ark";
+    private String signSecret = "";
+    private String signVersion = "v1";
+
+    private String headerAppId = "X-SmartArk-AppId";
+    private String headerTimestamp = "X-SmartArk-Timestamp";
+    private String headerNonce = "X-SmartArk-Nonce";
+    private String headerBodySha256 = "X-SmartArk-Body-SHA256";
+    private String headerSignature = "X-SmartArk-Signature";
+    private String headerSignVersion = "X-SmartArk-Sign-Version";
+}
+

