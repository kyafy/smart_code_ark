## Smart Code Ark - Environment Example
## 将本文件复制为 .env（不要提交 .env），按需修改

## MySQL（本地运行后端时一般用 localhost；docker compose 内用 mysql）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartark
DB_USER=smartark
DB_PASSWORD=smartark

## Redis（本地运行后端时一般用 localhost；docker compose 内用 redis）
REDIS_HOST=localhost
REDIS_PORT=6379

## JWT（开发环境示例；生产环境必须替换为强随机值）
JWT_SECRET=change-me
JWT_TTL_SECONDS=604800

## OpenAI 兼容模型服务（DashScope Compatible Mode 示例）
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_API_KEY=sk-62127047df334f8d9fab4483bb4a1c3e
MODEL_MOCK_ENABLED=false

## 模型名称（示例）
CHAT_MODEL=qwen3.5-plus
CODE_MODEL=qwen3-coder-next
MODEL_CONNECT_TIMEOUT_MS=10000
MODEL_READ_TIMEOUT_MS=120000
